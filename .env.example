# Dashboard (frontend) env — used at build time and injected into the client bundle.
# Only VITE_* variables are exposed to the browser.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhb...

# Public HTTPS URL of your Helix worker (the VPS process in ./worker).
# Used for encrypting + shipping your funding private key.
VITE_WORKER_URL=https://helix-worker.your-domain.com
