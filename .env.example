# Dashboard (frontend) env — used at build time and injected into the client bundle.
# Only PUBLIC_* variables are exposed to the browser.

# Your own Supabase project (renamed to avoid reserved Lovable prefixes).
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Public HTTPS URL of your Helix worker (the VPS process in ./worker).
# Used for encrypting + shipping your funding private key.
PUBLIC_WORKER_URL=https://helix-worker.your-domain.com

# Server-side Supabase credentials for TanStack server functions.
SERVER_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SERVER_SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Single user this bot instance manages.
HELIX_USER_ID=00000000-0000-0000-0000-000000000000
